{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-2/refs/heads/main/core/tauri-config-schema/schema.json",
  "productName": "dedup",
  "version": "0.1.1",
  "identifier": "com.dedup.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "dedup — Content-Addressed File Browser",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
